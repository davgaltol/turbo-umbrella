<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER_LEFT" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" spacing="10.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.emergencias.gui.UIController">
   <children>
      <Label text="Seleccione tipo de herida:">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Label>
      <CheckBox fx:id="cod01Check" mnemonicParsing="false" text="Cod01 - Inconsciencia" />
      <CheckBox fx:id="cod02Check" mnemonicParsing="false" text="Cod02 - Fallo Respiratorio" />
      <CheckBox fx:id="cod03Check" mnemonicParsing="false" text="Cod03 - Sangrado Abundante" />
      <CheckBox fx:id="cod04Check" mnemonicParsing="false" text="Cod04 - Golpe Grave" />
      <Label text="Opciones de envío:">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </Label>
      <CheckBox fx:id="simulacionCheck" mnemonicParsing="false" text="Simular falta de cobertura" />
      <Button fx:id="alertaButton" mnemonicParsing="false" onAction="#handleGenerarAlerta" prefHeight="35.0" prefWidth="604.0" text="GENERAR ALERTA">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </Button>
      <Label text="Resultados:">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </Label>
      <TextArea fx:id="resultadoArea" editable="false" prefHeight="200.0" prefWidth="200.0" wrapText="true" />
   </children>
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>
</VBox>
